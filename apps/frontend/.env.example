# UnitFlow AI Frontend environment example
# Copy this file to .env.local when you need explicit values.
#
# If this is left unset in local dev, the app uses the current browser
# hostname with backend port 8000. That makes both of these work:
# - http://localhost:5173 -> http://localhost:8000
# - http://192.168.0.105:5173 -> http://192.168.0.105:8000

VITE_API_BASE_URL=
