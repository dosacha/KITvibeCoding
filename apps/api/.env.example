APP_ENV=development
DATABASE_URL=sqlite:///./unitflow.db
AUTO_CREATE_SCHEMA=false
JWT_SECRET=change-me-with-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_STRATEGY_EXPLANATION_ENABLED=true
OPENAI_STRATEGY_EXPLANATION_TIMEOUT_SECONDS=8
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
UNITFLOW_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
